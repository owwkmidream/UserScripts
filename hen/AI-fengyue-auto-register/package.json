{
  "name": "ai-fengyue-auto-register",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rolldown -c",
    "postbuild": "node ./scripts/open-userscript.mjs",
    "build:watch": "rolldown -c -w",
    "release": "node ./scripts/release.mjs",
    "release:patch": "node ./scripts/release.mjs --bump patch",
    "release:minor": "node ./scripts/release.mjs --bump minor",
    "release:major": "node ./scripts/release.mjs --bump major"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-beta.0"
  }
}
